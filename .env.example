# =============================================================================
# CIG Turf Booking System — Environment Variables
# Copy to `.env` for local development. Set the same keys in Vercel → Settings → Environment Variables.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Public site URL (no trailing slash). Production: https://chandnaindoorground.in
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Display name shown in UI and emails until business settings load
NEXT_PUBLIC_APP_NAME=Chandna Indoor Ground

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Project URL → Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon/public key (safe for browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key (server only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PostgreSQL connection string
# Production: use Supabase connection pooler (port 6543, ?pgbouncer=true)
DATABASE_URL=postgresql://postgres:password@localhost:5432/cig_turf

# Optional: direct connection for Prisma migrations (port 5432)
# DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# Razorpay
# -----------------------------------------------------------------------------
# Test keys: rzp_test_* | Live keys: rzp_live_*
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Public key for client checkout (usually same as RAZORPAY_KEY_ID)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id

# Optional: Razorpay Dashboard → Webhooks → secret (falls back to RAZORPAY_KEY_SECRET)
# RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# -----------------------------------------------------------------------------
# Brevo (transactional email)
# -----------------------------------------------------------------------------
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=bookings@chandnaindoorground.in
BREVO_SENDER_NAME=Chandna Indoor Ground

# -----------------------------------------------------------------------------
# Error monitoring (optional — disabled when unset)
# -----------------------------------------------------------------------------
# SENTRY_DSN=https://example@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# Google OAuth (configure in Supabase Dashboard → Authentication → Providers)
# -----------------------------------------------------------------------------
# Authorized redirect URLs (add all that apply):
#   http://localhost:3001/auth/callback
#   https://chandnaindoorground.in/auth/callback
#   https://your-project.vercel.app/auth/callback

# -----------------------------------------------------------------------------
# Vercel (set automatically on Vercel — do not set locally)
# -----------------------------------------------------------------------------
# VERCEL_ENV=development | preview | production
# VERCEL_URL=your-deployment.vercel.app
